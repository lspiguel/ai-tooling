{
  "$schema": "../schema/context-exporter.schema.json",
  "spec": "FormsAndViews",
  "version": "1.0.0",
  "legal": "LEGAL.md",
  "frontMatter": {
    "generatedBy": "D365 CE Context Exporter",
    "purpose": "AI assistant grounding context — forms and views"
  },
  "python": {
    "interpreter": "auto"
  },
  "transformation": "forms-and-views.sbn",
  "queries": [
    {
      "id": "forms-and-views",
      "type": "webapi",
      "path": "EntityDefinitions?$select=LogicalName,DisplayName&$expand=SystemForms($select=Name,Type,IsDefault),SavedQueries($select=Name,QueryType,IsDefault)",
      "resultKey": "formsAndViews",
      "maxRecords": 500
    }
  ]
}
