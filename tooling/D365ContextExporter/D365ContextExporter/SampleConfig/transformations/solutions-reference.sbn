## Custom Entities

{{
  custom_ents = []
  std_ents = []
  virtual_ents = []
  for e in entities
    is_virtual = e.IsVirtual != null && e.IsVirtual
    if is_virtual
      virtual_ents = virtual_ents | array.add e
    else if e.IsCustomEntity
      custom_ents = custom_ents | array.add e
    else
      std_ents = std_ents | array.add e
    end
  end
  custom_ents = custom_ents | array.sort 'LogicalName'
  std_ents = std_ents | array.sort 'LogicalName'
  virtual_ents = virtual_ents | array.sort 'LogicalName'
}}
{{ for entity in custom_ents }}
{{
  dn = entity.DisplayName | display_label entity.LogicalName
  desc = entity.Description | display_label ""
  custom_attrs = []
  for attr in (entity.Attributes ?? [])
    if attr.IsCustomAttribute
      custom_attrs = custom_attrs | array.add attr
    end
  end
}}
{{ if custom_attrs.size > 0 }}

### {{ entity.LogicalName }} — "{{ dn }}"
{{ if entity.IsActivity }}*(custom activity)*{{ end }}
{{ if desc != "" }}{{ desc }}{{ end }}

**Fields:**

| Logical Name | Display Name | Type | Req |
|---|---|---|---|
{{ for attr in custom_attrs | array.sort 'LogicalName' -}}
{{ adn = attr.DisplayName | display_label attr.LogicalName -}}
{{ req = attr.RequiredLevel | req_indicator -}}
| {{ attr.LogicalName }} | {{ adn }} | {{ attr.AttributeType | attr_type_abbrev }} | {{ req }} |
{{ end }}
**Forms:** {{ forms | entity_forms entity.LogicalName | format_forms }}
**Views:** {{ views | entity_views entity.LogicalName | format_views }}
{{ end }}
{{ end }}

