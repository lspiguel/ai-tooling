## Custom APIs

{{
  api_resp_map = {}
  for group in customApiResponses | group_by_key "uniquename"
    api_resp_map[group.key] = group.items
  end
}}

| API | Request Params | Response |
|---|---|---|
{{ for group in customApiRequests | group_by_key "uniquename" -}}
{{ if group.key != null && group.key != "" -}}
{{-
  params = []
  for r in group.items
    pname = r["req.uniquename"]
    if pname != null && pname != ""
      ptype = r["req.type"] | api_param_type
      params = params | array.add (pname + "(" + ptype + ")")
    end
  end
  resp_rows = api_resp_map[group.key] ?? []
  resp_parts = []
  for r in resp_rows
    rname = r["resp.uniquename"]
    if rname != null && rname != ""
      rtype = r["resp.type"] | api_param_type
      resp_parts = resp_parts | array.add (rname + "(" + rtype + ")")
    end
  end
-}}
| {{ group.key }} | {{ if params.size > 0 }}{{ params | array.join ", " }}{{ else }}—{{ end }} | {{ if resp_parts.size > 0 }}{{ resp_parts | array.join ", " }}{{ else }}—{{ end }} |
{{ end -}}
{{ end }}

