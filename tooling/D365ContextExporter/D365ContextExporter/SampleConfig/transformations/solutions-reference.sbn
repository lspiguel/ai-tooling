## Processes

### Classic Workflows

{{
  classic_wfs = []
  cloud_wfs = []
  brs = []
  for wf in workflows
    if wf.category == 0
      classic_wfs = classic_wfs | array.add wf
    else if wf.category == 5
      cloud_wfs = cloud_wfs | array.add wf
    else if wf.category == 2
      brs = brs | array.add wf
    end
  end
  classic_wfs = classic_wfs | array.sort "name"
  cloud_wfs = cloud_wfs | array.sort "name"
}}
{{ for ent_group in classic_wfs | group_by_key "primaryentity" -}}
{{ if ent_group.key != null && ent_group.key != "" }}

