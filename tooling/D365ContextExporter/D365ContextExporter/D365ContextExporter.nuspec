<?xml version="1.0"?>
<!--
To generate a nuget (run from the ai-tooling repo folder):
nuget.exe pack tooling\D365ContextExporter\D365ContextExporter\D365ContextExporter.nuspec -BasePath tooling\D365ContextExporter\D365ContextExporter -OutputDirectory nupkg -Symbols -SymbolPackageFormat snupkg
-->
<package>
  <metadata>
    <id>Lspiguel.Xrm.D365ContextExporter</id>
    <version>1.2026.7.1</version>
    <title>D365 CE Context Exporter for XrmToolBox</title>
    <authors>Luciano Spiguel</authors>
    <owners>Luciano Spiguel</owners>
    <projectUrl>https://github.com/lspiguel/ai-tooling</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/lspiguel/ai-tooling/refs/heads/main/tooling/D365ContextExporter/D365ContextExporter/d365-context-exporter-icon-c-128px-transparent.png</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <summary>XrmToolBox plugin to produce grounding files for AI assistants</summary>
    <description>
      XrmToolBox plugin that executes FetchXML and Web API queries against a Dataverse environment, serialises results to an intermediate JSON file, and uses an internal scripting post-processor to produce Markdown grounding files for non-agentic AI assistants.
    </description>
    <releaseNotes>This version fixes some issues on the sample config, add some new specs, upgrades Scriban to avoid a vulnerability.</releaseNotes>
    <copyright>Copyright 2026- Luciano Spiguel</copyright>
    <tags>XrmToolBox Documentation AI Markdown D365 Dataverse Grounding</tags>
    <dependencies>
      <dependency id="XrmToolBox" version="1.2025.10.74" />
    </dependencies>
    <license type="expression">MIT</license>
    <readme>readme.md</readme>
  </metadata>
  <files>
    <!-- License and readme must be at package root -->
    <file src="..\..\..\LICENSE" target="LICENSE" />
    <file src="..\README.md" target="readme.md" />

    <!-- Plugin DLL and debug symbols -->
    <file src="bin\Release\net48\D365ContextExporter.dll" target="lib\net472\Plugins" />
    <!-- Disconnect this line if symbols are not needed -->
    <file src="bin\Release\net48\D365ContextExporter.pdb" target="lib\net472\Plugins" />

    <!-- Schema for IDE IntelliSense (installed alongside plugin)
    <file src="..\schema\context-exporter.schema.json" target="lib\net472\Plugins\schema" /> -->

    <!-- Runtime dependencies (Scriban is now source-embedded into the plugin DLL) -->
    <file src="bin\Release\net48\System.Text.Encodings.Web.dll" target="lib\net472\Plugins\D365ContextExporter" />
    <file src="bin\Release\net48\System.Text.Json.dll" target="lib\net472\Plugins\D365ContextExporter" />
  </files>
</package>
