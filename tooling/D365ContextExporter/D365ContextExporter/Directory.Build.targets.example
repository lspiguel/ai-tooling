<!--
  Copy this file to Directory.Build.targets (in the same folder as D365ContextExporter.csproj)
  and update the XrmToolBoxPluginsDir path to match your local XrmToolBox installation.
  This file is NOT committed to source control — add it to .gitignore.

  This replaces the machine-specific xcopy PostBuild that was removed from D365ContextExporter.csproj.
-->
<Project>
  <PropertyGroup>
    <!-- Edit this to point to your local XrmToolBox Plugins folder. -->
    <XrmToolBoxPluginsDir>C:\Users\YourName\AppData\Roaming\MscrmTools\XrmToolBox\Plugins</XrmToolBoxPluginsDir>
  </PropertyGroup>

  <Target Name="CopyToXrmToolBox" AfterTargets="Build"
          Condition="'$(Configuration)' == 'Debug' AND Exists('$(XrmToolBoxPluginsDir)')">

    <!-- Plugin DLL and symbols -->
    <Copy SourceFiles="$(TargetPath)"
          DestinationFolder="$(XrmToolBoxPluginsDir)"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb"
          DestinationFolder="$(XrmToolBoxPluginsDir)"
          SkipUnchangedFiles="true" />

    <!-- IronPython runtime DLLs -->
    <ItemGroup>
      <_IronPythonDlls Include="$(TargetDir)IronPython.dll;
                                $(TargetDir)IronPython.Modules.dll;
                                $(TargetDir)Microsoft.Dynamic.dll;
                                $(TargetDir)Microsoft.Scripting.dll;
                                $(TargetDir)Microsoft.Scripting.Metadata.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_IronPythonDlls)"
          DestinationFolder="$(XrmToolBoxPluginsDir)"
          SkipUnchangedFiles="true" />

    <!-- IronPython standard library (Lib folder) -->
    <ItemGroup>
      <_IronPythonLib Include="$(TargetDir)Lib\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_IronPythonLib)"
          DestinationFiles="@(_IronPythonLib->'$(XrmToolBoxPluginsDir)\Lib\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />

    <Message Text="[PostBuild] Copied $(TargetFileName) + IronPython runtime to $(XrmToolBoxPluginsDir)" Importance="High" />
  </Target>
</Project>
