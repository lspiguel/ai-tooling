<fetch version="1.0" output-format="xml-platform" mapping="logical">
  <entity name="solutioncomponent">
    <attribute name="solutioncomponentid" />
    <attribute name="componenttype" />
    <attribute name="objectid" />
    <link-entity name="solution" from="solutionid" to="solutionid" alias="solution" link-type="inner">
      <attribute name="ismanaged" />
      <attribute name="uniquename" />
      <filter type="and">
        <condition attribute="ismanaged" operator="eq" value="0" />
      </filter>
      <link-entity name="publisher" from="publisherid" to="publisherid" alias="P">
        <attribute name="friendlyname" />
        <filter type="and">
          <condition attribute="friendlyname" operator="not-begin-with" value="Microsoft" />
          <condition attribute="friendlyname" operator="not-begin-with" value="Default Publisher" />
          <condition attribute="friendlyname" operator="not-begin-with" value="CDS Default Publisher" />
        </filter>
      </link-entity>
    </link-entity>
    <link-entity name="entity" from="entityid" to="objectid" link-type="outer" alias="entity">
      <attribute name="logicalname" />
      <link-entity name="attribute" from="attributeof" to="entityid" link-type="outer" alias="attribute">
        <attribute name="attributetypeid" />
        <attribute name="name" />
        <attribute name="physicalname" />
      </link-entity>
    </link-entity>
  </entity>
</fetch>